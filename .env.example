# ============================================
# Let Me Drive - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# MongoDB Connection String
# Local: mongodb://localhost:27017/letmedrive
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/letmedrive
MONGO_URI=mongodb://localhost:27017/letmedrive

# JWT Secret Key (change this to a strong random string in production)
JWT_SECRET=letmedrive_super_secret_key_change_in_production

# Server Port
PORT=5000

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000
